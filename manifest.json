{
  "name": "Tab Repeater!",
  "description": "A simple Chrome extension to open multiple copies of a tab for stress testing.",
  "version": "1.0",
  "manifest_version": 3,
  "author": "Sara Awwad",
  "homepage_url": "https://github.com/saraAwaad/TabRepeater",
  "icons": {
	"48": "/assets/icons/url.png"
  },
  "action": {
	"default_popup": "popup.html",
	"default_icon": {
	  "48": "/assets/icons/url.png"
	}
  },
  "permissions": [
	"tabs"
  ],
  "background": {
	"service_worker": "background.js"
  }
}
